# Carson — frontend environment variables
# Copy this file to .env.local and fill in your values

# Firebase Web App config (from Firebase Console → Project Settings → Your Apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=carson-app-cf3f7.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=carson-app-cf3f7
VITE_FIREBASE_APP_ID=

# Backend API URL (leave empty for same-origin / Vercel proxy)
VITE_API_URL=
